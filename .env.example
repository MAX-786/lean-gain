# Supabase — Project → Settings → API
# Both are client-safe (the publishable key is protected by Row-Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Server-only secret (NOT needed for the app or v1 deploy). Only if you later add
# seed scripts run from Node or scheduled push jobs. Never prefix a secret with NEXT_PUBLIC.
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
